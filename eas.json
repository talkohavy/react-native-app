{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      // Enables corepack so builds use the exact package manager version
      // pinned in package.json's "packageManager" field (pnpm@11.5.2),
      // instead of whatever pnpm version the build image ships with.
      "corepack": true,
      "env": {
        /**
         * Enable Gradle's build cache on EAS: task outputs (compiled
         * classes/dex/native) are stored and reused across builds. First build
         * populates it; subsequent builds restore and skip unchanged tasks
         * (Expo reports ~50% faster). Keyed off the pnpm lockfile hash.
         */
        "EAS_GRADLE_CACHE": "1"
      }
    },
    /**
     * Development is for creating builds for local development testing
     */
    "development": {
      "extends": "base", // inherit the "corepack" setting above
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        // "apk" is what "distribution": "internal" already defaults to
        // (AABs can't be installed directly on a device); spelled out
        // explicitly here for clarity.
        "buildType": "apk"
      },
      "ios": {
        // Builds for the iOS Simulator instead of a physical device, so no
        // Apple credentials/provisioning are needed for local dev testing.
        "simulator": true
      }
    },
    /**
     * Preview is for creating production builds for testing
     * Creates an APK file, which can be installed on a physical device.
     */
    "preview": {
      "extends": "base", // inherit the "corepack" setting above
      "distribution": "internal",
      "android": {
        // "apk" is what "distribution": "internal" already defaults to
        // (AABs can't be installed directly on a device); spelled out
        // explicitly here for clarity.
        "buildType": "apk"
      }
    },
    /**
     * Production is for creating production builds for submission to the Play Store
     * Creates an AAB file, which can be submitted to the Play Store.
     */
    "production": {
      "extends": "base", // inherit the "corepack" setting above
      "autoIncrement": true,
      "android": {
        // "app-bundle" is the actual EAS Build default for buildType
        // (produces an .aab for Play Store submission); spelled out
        // explicitly here for clarity.
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
